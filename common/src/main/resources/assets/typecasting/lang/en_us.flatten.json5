{
  typecasting: {
    book: {
      patterns: {
        eval: {
          "": "Computational Meta-Eval",
          set_op_limit_trap: "Remove a list of patterns and a number from the stack, then, for the rest of this _Hex, cast the given patterns the first time $(l:patterns/meta#hexcasting:thanatos)$(action)Thanatos' Reflection/$ would push a smaller number than the given number."
        },
        spells: {
          subroutines: {
            "": "Machinations",
            compile_subroutine: "Remove a list of patterns from the stack, then use them to create a $(thing)machination/$. Costs about five $(l:items/amethyst)$(item)Charged Amethyst/$.",
            decompile_subroutine: "Remove a $(thing)machination/$ from the stack, then convert it back into a list of patterns. Costs about five $(l:items/amethyst)$(item)Charged Amethyst/$.",
          },
        },
      },
    },

    tooltip: {
      subroutine_contents: "{{%s}}",
    },
  },

  hexcasting: {
    action: {
      "typecasting:": {
        compile_subroutine: "Machinate",
        decompile_subroutine: "Decimate",
        set_op_limit_trap: "Thanatos' Gambit",
      },

      book: {
        "typecasting:": {
        },
      },
    },

    iota: {
      "typecasting:": {
        subroutine: {
          "": "Machination",
          desc: "a machination",
        },
      },
    },

    mishap: {
      typecasting: {
        invalid_subroutine_pattern: "The pattern %s cannot be added to a machination",
        subroutine_size: "Exceeded the size limit of a machination",
      },
      "invalid_value.typecasting": {
        pattern_list: "a list of patterns",
        subroutine: "a machination",
      },
    },
  },

  text: {
    "autoconfig.typecasting": {
      title: "Type Casting Config",

      category: {
        client: "Client",
        server: "Server",
      },

      option: {
        client: {
        },

        server: {
          maxSubroutineSize: {
            "": "Max Machination Size",
            "@Tooltip": "Maximum number of patterns allowed in a machination iota",
          },

          discountSubroutineOps: {
            "": "Discount Machination Ops",
            "@Tooltip": "Whether machinations should only cost 1 op to execute",
          },
        },
      },
    },
  },
}
